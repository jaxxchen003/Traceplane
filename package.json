    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "prisma db push && node prisma/seed.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prisma": "^6.10.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
