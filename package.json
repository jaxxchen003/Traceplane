{
  "name": "enterprise-agent-work-graph",
  "version": "1.0.0",
  "description": "让多个 Agent 的工作接成一条不断档、可回看、可交接的工作主线。",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "start:demo": "node scripts/start-demo.mjs",
    "mcp:start": "node scripts/mcp-server.mjs",
    "mcp:test": "node scripts/test-mcp.mjs",
    "cloud:verify": "node scripts/verify-cloud-config.mjs",
    "cloud:manifest": "node scripts/print-cloud-env-manifest.mjs",
    "cloud:verify:supabase": "node scripts/verify-supabase-connection.mjs",
    "cloud:verify:r2": "node scripts/verify-r2-connection.mjs",
    "workspace:sync": "node scripts/sync-local-workspace.mjs",
    "mcp:host": "node scripts/setup-mcp-host.mjs",
    "claude:setup": "node scripts/setup-claude-project.mjs",
    "claude:verify": "node scripts/verify-claude-setup.mjs",
    "gemini:setup": "node scripts/setup-gemini-project.mjs",
    "gemini:verify": "node scripts/verify-gemini-setup.mjs",
    "opencode:setup": "node scripts/setup-opencode-project.mjs",
    "opencode:verify": "node scripts/verify-opencode-setup.mjs",
    "import:transcript": "node scripts/import-transcript.mjs",
    "normalize:opencode": "node scripts/normalize-opencode-export.mjs",
    "claude:hook:test": "node scripts/test-claude-hook-bridge.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "ci": "npm run lint && npm run build && npm run test:run",
    "db:generate": "prisma generate && prisma generate --schema prisma/schema.postgres.prisma",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "prisma db push && node prisma/seed.mjs",
    "db:cloud:generate": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:cloud:push": "node scripts/db-cloud-push.mjs",
    "db:cloud:seed": "node prisma/seed-cloud.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@prisma/client": "^6.10.1",
    "clsx": "^2.1.1",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "prisma": "^6.10.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
